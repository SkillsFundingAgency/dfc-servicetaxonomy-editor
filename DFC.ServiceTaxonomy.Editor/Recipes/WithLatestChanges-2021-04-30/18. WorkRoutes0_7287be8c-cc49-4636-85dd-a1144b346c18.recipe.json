      "Title": "Accounting technician"
    },
    "WorkRoute": {
      "Description": {
        "Html": "\u003Cp\u003EYou could start as an accounts clerk or bookkeeper while you study to become an accounting technician.\u003C/p\u003E\u003Cp\u003EThe \u003Ca href=\u0022https://www.aat.org.uk/\u0022\u003EAssociation of Accounting Technicians\u003C/a\u003E (AAT) and the \u003Ca href=\u0022http://www.accaglobal.com\u0022\u003EAssociation of Chartered Certified Accountants\u003C/a\u003E (ACCA) have information on accounting courses.\u003C/p\u003E"
      }
