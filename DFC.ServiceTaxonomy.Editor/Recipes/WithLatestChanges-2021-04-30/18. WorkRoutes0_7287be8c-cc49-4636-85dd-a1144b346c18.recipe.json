  {
    "TitlePart": {
      "Title": "Accommodation warden"
    },
    "WorkRoute": {
      "Description": {
        "Html": "\u003Cp\u003EYou could work as a warden\u0027s assistant and become qualified through on-the-job training. You could also work your way up by doing customer service courses.\u003C/p\u003E"
      }
