  {
    "TitlePart": {
      "Title": "Admin assistant"
    },
    "VolunteeringRoute": {
      "Description": {
        "Html": "\u003Cp\u003EYou could volunteer with a charity in an office based role to get some experience and skills that are useful for administration work.\u003C/p\u003E"
      }
    },
    "GraphSyncPart": {
