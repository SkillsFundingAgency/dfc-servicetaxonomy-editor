  {
    "TitlePart": {
      "Title": "Social worker"
    },
    "VolunteeringRoute": {
      "Description": {
        "Html": "\u003Cp\u003EExperience of working with vulnerable groups or children is essential for most courses and jobs.\u003C/p\u003E\u003Cp\u003EBefore becoming qualified as a social worker, you can apply to be a social work assistant or support worker. You can also get skills and experience by volunteering in the community, with a charity or through paid work.\u003C/p\u003E\u003Cp\u003EYou can get more information on volunteering opportunities in your area from \u003Ca href=\u0022https://do-it.org/\u0022\u003EDo-it\u003C/a\u003E.\u003C/p\u003E"
      }
    },
    "GraphSyncPart": {
      "Text": "\u003C\u003Ccontentapiprefix\u003E\u003E/volunteeringroute/7ed7db0f-b607-4a17-874f-c859123d6417"
