  {
    "TitlePart": {
      "Title": "Primary school teacher"
    },
    "VolunteeringRoute": {
      "Description": {
        "Html": "\u003Cp\u003EYou\u0027ll find it helpful to get some experience of working with children though this is not essential. You can do this through paid work or by \u003Ca href=\u0022https://getintoteaching.education.gov.uk/arranging-school-experience-independently\u0022\u003Evolunteering at a school\u003C/a\u003E, helping at an after school club or working on a holiday scheme.\u003C/p\u003E"
      }
    },
    "GraphSyncPart": {
      "Text": "\u003C\u003Ccontentapiprefix\u003E\u003E/volunteeringroute/2b9e3017-3d1e-4b33-a9ea-d0056ac6e607"
    },
    "ContentItemId": "4xsqvzkvd6e0xzcnyky18gstn6",
