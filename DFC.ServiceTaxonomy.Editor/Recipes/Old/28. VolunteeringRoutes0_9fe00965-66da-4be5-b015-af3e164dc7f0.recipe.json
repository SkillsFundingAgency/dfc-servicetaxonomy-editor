  {
    "TitlePart": {
      "Title": "Sales assistant"
    },
    "VolunteeringRoute": {
      "Description": {
        "Html": "\u003Cp\u003EGetting experience volunteering in a charity shop could lead into paid work.\u003C/p\u003E"
      }
    },
    "GraphSyncPart": {
