  {
    "TitlePart": {
      "Title": "Emergency medical dispatcher"
    },
    "VolunteeringRoute": {
      "Description": {
        "Html": "\u003Cp\u003EPaid or unpaid experience of working in healthcare would be useful. You could contact the voluntary services co-ordinator or manager at your \u003Ca href=\u0022https://www.nhs.uk/servicedirectories/pages/nhstrustlisting.aspx\u0022\u003Elocal NHS trust\u003C/a\u003E for advice about opportunities.\u003C/p\u003E"
      }
    },
    "GraphSyncPart": {
      "Text": "\u003C\u003Ccontentapiprefix\u003E\u003E/volunteeringroute/2726d4e6-d018-492d-93e3-704af5cc0935"
    },
