  {
    "TitlePart": {
      "Title": "MP"
    },
    "VolunteeringRoute": {
      "Description": {
        "Html": "\u003Cp\u003EMost people show their commitment through campaigning and volunteering for their party.\u003C/p\u003E\u003Cp\u003EYou can get other useful experience from:\u003Cul\u003E\u003Cli\u003Eserving as a local councillor\u003C/li\u003E\u003Cli\u003Ebeing active in a trade union\u003C/li\u003E\u003Cli\u003Ebeing involved in student politics\u003C/li\u003E\u003Cli\u003Eworking as a researcher or caseworker for an existing MP\u003C/li\u003E\u003C/ul\u003E\u003C/p\u003E"
      }
    },
    "GraphSyncPart": {
      "Text": "\u003C\u003Ccontentapiprefix\u003E\u003E/volunteeringroute/93df3620-3768-48b6-8ffe-ed655788a355"
