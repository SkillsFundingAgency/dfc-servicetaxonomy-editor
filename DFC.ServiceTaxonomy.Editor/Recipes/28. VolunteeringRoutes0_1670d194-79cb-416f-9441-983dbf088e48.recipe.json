  {
    "TitlePart": {
      "Title": "Care worker"
    },
    "VolunteeringRoute": {
      "Description": {
        "Html": "\u003Cp\u003EYou could do voluntary work with an organisation that supports vulnerable people, for example a:\u003Cul\u003E\u003Cli\u003Ecare home\u003C/li\u003E\u003Cli\u003Echarity\u003C/li\u003E\u003Cli\u003Ehospital\u003C/li\u003E\u003Cli\u003Ehospice\u003C/li\u003E\u003C/ul\u003E\u003C/p\u003E\u003Cp\u003E\u003Ca href=\u0022https://do-it.org/\u0022\u003EDo-it\u003C/a\u003E has more information on voluntary opportunities in your area.\u003C/p\u003E"
      }
    },
    "GraphSyncPart": {
      "Text": "\u003C\u003Ccontentapiprefix\u003E\u003E/volunteeringroute/2a3f3632-6387-4026-a48d-6d962a15e7c1"
    },
