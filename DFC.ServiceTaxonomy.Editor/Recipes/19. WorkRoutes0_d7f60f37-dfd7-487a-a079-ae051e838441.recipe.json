    "TitlePart": {
      "Title": "Acoustics consultant"
    },
    "WorkRoute": {
      "Description": {
        "Html": "\u003Cp\u003EYou may be able to start work as an assistant or trainee technician and, with further training, qualify as an engineer or consultant.\u003C/p\u003E\u003Cp\u003EYou\u0027ll normally need at least 4 GCSEs at grades 9 to 4 (A* to C), including two science subjects. A levels or equivalent, like applied science, may be acceptable. Employers may also consider relevant work experience like non-destructive testing, if you do not have academic qualifications.\u003C/p\u003E"
      }
    },
    "GraphSyncPart": {
      "Text": "\u003C\u003Ccontentapiprefix\u003E\u003E/workroute/49f306d5-5e6e-428a-b776-ce6838768520"
