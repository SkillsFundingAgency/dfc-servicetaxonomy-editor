      "Title": "Advertising account planner"
    },
    "OtherRoute": {
      "Description": {
        "Html": "\u003Cp\u003EYou could apply for a graduate training scheme and learn on the job if you have a degree.\u003C/p\u003E\u003Cp\u003ESome large agencies recruit graduates as trainee planners, while others recruit them as trainee advertising account executives or advertising account managers.\u003C/p\u003E"
