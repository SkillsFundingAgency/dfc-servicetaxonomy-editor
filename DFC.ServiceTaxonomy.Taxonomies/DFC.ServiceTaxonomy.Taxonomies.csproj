<Project Sdk="Microsoft.NET.Sdk.Razor">
  <PropertyGroup>
    <TargetFramework>net8.0</TargetFramework>
    <AddRazorSupportForMvc>true</AddRazorSupportForMvc>
    <TreatWarningsAsErrors>true</TreatWarningsAsErrors>
    <EnableNETAnalyzers>true</EnableNETAnalyzers>
    <AnalysisLevel>latest</AnalysisLevel>
    <EnforceCodeStyleInBuild>true</EnforceCodeStyleInBuild>
  </PropertyGroup>
  <ItemGroup>
    <FrameworkReference Include="Microsoft.AspNetCore.App" />
  </ItemGroup>
  <ItemGroup>
    <PackageReference Include="OrchardCore.Admin.Abstractions" Version="2.0.2" />
    <PackageReference Include="OrchardCore.Apis.GraphQL.Abstractions" Version="2.0.2" />
    <PackageReference Include="OrchardCore.ContentManagement.Abstractions" Version="2.0.2" />
    <PackageReference Include="OrchardCore.ContentManagement.GraphQL" Version="2.0.2" />
    <PackageReference Include="OrchardCore.ContentManagement" Version="2.0.2" />
    <PackageReference Include="OrchardCore.Contents.Core" Version="2.0.2" />
    <PackageReference Include="OrchardCore.ContentTypes.Abstractions" Version="2.0.2" />
    <PackageReference Include="OrchardCore.Data.Abstractions" Version="2.0.2" />
    <PackageReference Include="OrchardCore.DisplayManagement" Version="2.0.2" />
    <PackageReference Include="OrchardCore.Indexing.Abstractions" Version="2.0.2" />
    <PackageReference Include="OrchardCore.Infrastructure" Version="2.0.2" />
    <PackageReference Include="OrchardCore.Liquid.Abstractions" Version="2.0.2" />
    <PackageReference Include="OrchardCore.Module.Targets" Version="2.0.2" />
    <PackageReference Include="OrchardCore.Navigation.Core" Version="2.0.2" />
    <PackageReference Include="OrchardCore.ResourceManagement" Version="2.0.2" />
    <PackageReference Include="OrchardCore.Settings.Core" Version="2.0.2" />
    <PackageReference Include="Fluid.Core" Version="2.11.1" />
    <PackageReference Include="OrchardCore.Title" Version="2.0.2" />
  </ItemGroup>
</Project>
